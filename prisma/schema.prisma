generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/**
 * User model for authentication and core profile data.
 */
model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique
  passwordHash  String    @map("password_hash")
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  role          String    @default("faculty") // 'admin' | 'faculty'
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  facultyProfile FacultyProfile?

  @@map("users")
}


/**
 * FacultyProfile extends the User model with academic-specific details.
 */
model FacultyProfile {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @unique @db.Uuid @map("user_id")
  employeeId        String?   @unique @map("employee_id")
  designation       String?
  employmentType    String?    @map("employment_type")
  maxUnitsPerSem    Int?       @map("max_units_per_sem")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  // Relationships
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  availabilities    FacultyAvailability[]
  sections          CourseSection[]

  @@map("faculty_profiles")
}

/**
 * Course model representing individual subjects offered.
 */
model Course {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String    @unique
  title         String
  units         Int
  description   String?
  createdAt     DateTime  @default(now()) @map("created_at")

  // Relationships
  sections      CourseSection[]

  @@map("courses")
}

/**
 * FacultyAvailability tracks when instructors are free to teach.
 */
model FacultyAvailability {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facultyId     String    @db.Uuid @map("faculty_id")
  semester      String
  academicYear  Int       @map("academic_year")
  dayOfWeek     String    @map("day_of_week")
  startTime     DateTime  @db.Time() @map("start_time")
  endTime       DateTime  @db.Time() @map("end_time")
  status        String    @default("available")
  note          String?
  createdAt     DateTime  @default(now()) @map("created_at")

  faculty       FacultyProfile @relation(fields: [facultyId], references: [id])

  @@unique([facultyId, semester, academicYear, dayOfWeek, startTime, endTime])
  @@map("faculty_availability")
}

/**
 * Room model representing physical classrooms or labs.
 */
model Room {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  roomNumber  String?   @map("room_number")
  building    String?
  capacity    Int?
  type        String?
  isActive    Boolean   @default(true) @map("is_active")

  schedules   SectionSchedule[]

  @@unique([building, roomNumber])
  @@map("rooms")
}

/**
 * CourseSection tracks specific instances of a course.
 */
model CourseSection {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId      String    @db.Uuid @map("course_id")
  facultyId     String?   @db.Uuid @map("faculty_id")
  sectionId     String    @db.Uuid @map("section_id")
  semester      String
  academicYear  Int       @map("academic_year")
  maxStudents   Int?      @map("max_students")
  status        String?   @default("open")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  course        Course    @relation(fields: [courseId], references: [id])
  faculty       FacultyProfile? @relation(fields: [facultyId], references: [id])
  section       Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  schedules     SectionSchedule[]

  @@unique([courseId, sectionId, semester, academicYear])
  @@map("course_sections")
}

/**
 * Program represents academic programs (e.g., BSIT, BSA).
 */
model Program {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String    @unique // e.g., "BSIT"
  name      String    // e.g., "Bachelor of Science in Information Technology"
  createdAt DateTime  @default(now()) @map("created_at")

  sections  Section[]

  @@map("programs")
}

/**
 * Section represents a specific year level and block under a program.
 */
model Section {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  programId String    @db.Uuid @map("program_id")
  yearLevel Int       @map("year_level") // e.g., 1, 2, 3, 4
  name      String    // e.g., "A", "B", "C"
  createdAt DateTime  @default(now()) @map("created_at")

  program        Program         @relation(fields: [programId], references: [id], onDelete: Cascade)
  courseSections CourseSection[]

  @@unique([programId, yearLevel, name])
  @@map("sections")
}

/**
 * SectionSchedule tracks specific meeting times and locations for a CourseSection.
 */
model SectionSchedule {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectionId     String    @db.Uuid @map("section_id")
  roomId        String?   @db.Uuid @map("room_id")
  dayOfWeek     String    @map("day_of_week")
  startTime     DateTime  @db.Time() @map("start_time")
  endTime       DateTime  @db.Time() @map("end_time")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  section       CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  room          Room?         @relation(fields: [roomId], references: [id])

  @@unique([sectionId, dayOfWeek, startTime, endTime])
  @@map("section_schedules")
}
