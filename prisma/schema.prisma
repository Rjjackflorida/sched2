generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique
  passwordHash  String    @map("password_hash")
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  role          String    @default("faculty") // 'admin' | 'faculty'
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  facultyProfile FacultyProfile?

  @@map("users")
}

model Department {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  code          String    @unique
  college       String?
  headFacultyId String?   @db.Uuid @map("head_faculty_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  headFaculty   FacultyProfile? @relation("DepartmentHead", fields: [headFacultyId], references: [id])
  courses       Course[]
  faculties     FacultyProfile[] @relation("DepartmentFaculty")

  @@map("departments")
}

model FacultyProfile {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @unique @db.Uuid @map("user_id")
  departmentId      String    @db.Uuid @map("department_id")
  employeeId        String?   @unique @map("employee_id")
  designation       String?
  employmentType    String?   @default("full_time") @map("employment_type")
  maxUnitsPerSem    Int?      @default(18) @map("max_units_per_sem")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  user              User      @relation(fields: [userId], references: [id])
  department        Department @relation("DepartmentFaculty", fields: [departmentId], references: [id])
  headOfDepartment  Department[] @relation("DepartmentHead")

  availabilities    FacultyAvailability[]
  sections          CourseSection[]

  @@map("faculty_profiles")
}

model Course {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  departmentId  String    @db.Uuid @map("department_id")
  code          String    @unique
  title         String
  units         Int
  description   String?
  createdAt     DateTime  @default(now()) @map("created_at")

  department    Department @relation(fields: [departmentId], references: [id])
  sections      CourseSection[]

  @@map("courses")
}

model FacultyAvailability {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facultyId     String    @db.Uuid @map("faculty_id")
  semester      String
  academicYear  Int       @map("academic_year")
  dayOfWeek     String    @map("day_of_week")
  startTime     DateTime  @db.Time() @map("start_time")
  endTime       DateTime  @db.Time() @map("end_time")
  status        String    @default("available")
  note          String?
  createdAt     DateTime  @default(now()) @map("created_at")

  faculty       FacultyProfile @relation(fields: [facultyId], references: [id])

  @@unique([facultyId, semester, academicYear, dayOfWeek, startTime, endTime])
  @@map("faculty_availability")
}

model Room {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  building  String?
  capacity  Int?
  type      String?
  isActive  Boolean   @default(true) @map("is_active")

  sections  CourseSection[]

  @@map("rooms")
}

model CourseSection {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId      String    @db.Uuid @map("course_id")
  facultyId     String?   @db.Uuid @map("faculty_id")
  roomId        String?   @db.Uuid @map("room_id")
  sectionCode   String    @map("section_code")
  semester      String
  academicYear  Int       @map("academic_year")
  dayOfWeek     String    @map("day_of_week")
  startTime     DateTime? @db.Time() @map("start_time")
  endTime       DateTime? @db.Time() @map("end_time")
  maxStudents   Int?      @map("max_students")
  status        String?   @default("open")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  course        Course    @relation(fields: [courseId], references: [id])
  faculty       FacultyProfile? @relation(fields: [facultyId], references: [id])
  room          Room?     @relation(fields: [roomId], references: [id])

  @@unique([courseId, sectionCode, semester, academicYear])
  @@unique([facultyId, dayOfWeek, startTime, endTime, semester, academicYear])
  @@unique([roomId, dayOfWeek, startTime, endTime, semester, academicYear])
  @@map("course_sections")
}
